{
    order coraza before respond
    security {
        paseto {
            primary yes
            issuer my-api
            symmetric yes
            secret "super-secret-paseto-key-must-be-32-bytes!"
            token_lifetime 24h
        }
    }
}

:8080 {
    # --- Apply Coraza WAF with OWASP CRS ---
    coraza {
        include @coraza_waf/coraza.conf
        include @coraza_waf/rules/*.conf
        mode on
    }

    route /api/* {
        authorize {
            paseto
        }

        respond "Protected API OK" 200
    }

    route {
        respond "Hello from Caddy + Coraza + PASETO" 200
    }
}
